\@writefile{lof}{\contentsline {figure}{\numberline {5.2}{\ignorespaces Entity relationship diagram for GiTrip's data model using Crow's foot notation. Primary keys are \underline  {underlined}. Solid-bordered entities are persisted as SQLite tables; dashed-bordered entities represent JSON structures embedded within the \texttt  {snapshot} column of each Commit. Crow's foot endpoints: double bar = exactly one, circle--bar = zero or one, fork--bar = one or many, fork--circle = zero or many.}}{15}{figure.caption.9}\protected@file@percent }
\newlabel{fig:erd}{{5.2}{15}{Entity relationship diagram for GiTrip's data model using Crow's foot notation. Primary keys are \underline {underlined}. Solid-bordered entities are persisted as SQLite tables; dashed-bordered entities represent JSON structures embedded within the \texttt {snapshot} column of each Commit. Crow's foot endpoints: double bar = exactly one, circle--bar = zero or one, fork--bar = one or many, fork--circle = zero or many}{figure.caption.9}{}}
