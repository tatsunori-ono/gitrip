<section class="container">
  <h1>Merge</h1>

  <style>
    .plan-preview-grid {
      display: flex;
      gap: 12px;
      margin-top: 8px;
    }

    .plan-preview-col {
      flex: 1;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 8px;
      background: #f9fafb;
      max-height: 260px;
      overflow: auto;
      font-size: 13px;
    }

    .plan-preview-col-heading {
      margin: 0 0 4px;
      font-size: 13px;
    }

    .plan-preview-day {
      margin-top: 6px;
    }

    .plan-preview-day-title {
      font-weight: 600;
      font-size: 12px;
      color: #111827;
    }

    .plan-preview-stop {
      margin-left: 10px;
      margin-top: 2px;
    }

    .plan-preview-stop .time {
      font-size: 12px;
      color: #6b7280;
    }

    .plan-preview-empty {
      font-size: 12px;
      color: #6b7280;
    }

    /* --- Diff highlighting --- */
    .diff-added {
      background: #ecfdf3;
      border-left: 3px solid #16a34a;
      padding-left: 7px;
      border-radius: 4px;
      margin: 2px 0;
    }
    .diff-removed {
      background: #fef2f2;
      border-left: 3px solid #ef4444;
      padding-left: 7px;
      border-radius: 4px;
      margin: 2px 0;
      text-decoration: line-through;
      opacity: 0.7;
    }
    .diff-modified {
      background: #fffbeb;
      border-left: 3px solid #f97316;
      padding-left: 7px;
      border-radius: 4px;
      margin: 2px 0;
    }

    .plan-diff-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-top: 8px;
    }
    .plan-diff-col-heading {
      font-size: 14px;
      font-weight: 700;
      margin: 0 0 6px;
    }
    .plan-diff-col-heading .branch-label {
      font-weight: 400;
      color: var(--muted);
      font-size: 12px;
    }

    .diff-legend {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin: 8px 0;
      font-size: 12px;
      color: var(--muted);
    }
    .diff-legend-item {
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }
    .diff-legend-swatch {
      width: 10px;
      height: 10px;
      border-radius: 2px;
      display: inline-block;
    }

    .plan-base-ref { margin-top: 8px; }
    .plan-base-ref > summary {
      cursor: pointer;
      font-size: 13px;
      color: var(--muted);
    }

    /* --- Diff map --- */
    .diff-map-frame {
      position: relative;
      border-radius: 12px;
      overflow: hidden;
      height: 360px;
      background: #e5e7eb;
    }
    .diff-map-frame .leaflet-container {
      width: 100%;
      height: 100%;
    }

    /* --- Conflict mini-cards --- */
    .conflict-compare {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 8px;
      margin-top: 6px;
      font-size: 13px;
    }
    .conflict-compare-card {
      padding: 6px 8px;
      border-radius: 6px;
      border: 1px solid var(--border);
      background: #f9fafb;
    }
    .conflict-compare-card .label {
      font-size: 11px;
      font-weight: 600;
      color: var(--muted);
      margin-bottom: 2px;
    }

    /* --- Timeline side-by-side --- */
    .merge-timeline-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
      margin-top: 10px;
    }

    .merge-timeline-col {
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 8px;
      background: #fff;
    }

    .merge-timeline-title {
      font-size: 12px;
      font-weight: 600;
      color: #111827;
      margin-bottom: 6px;
    }

    .merge-day {
      margin-top: 6px;
    }

    .merge-day-title {
      font-size: 12px;
      color: #6b7280;
      margin-bottom: 4px;
    }

    .merge-timeline {
      margin-top: 6px;
    }

    .merge-timeline svg {
      width: 100%;
      height: 100px;
      display: block;
      overflow: hidden;
    }

    .merge-conflict rect.tl-block-rect {
      stroke: #ef4444;
      stroke-width: 1.5px;
      fill: #fde2e2;
    }
    .tl-diff-added rect.tl-block-rect { fill: #bbf7d0; stroke: #16a34a; stroke-width: 1.2px; }
    .tl-diff-removed rect.tl-block-rect { fill: #fecaca; stroke: #ef4444; stroke-width: 1.2px; opacity: 0.5; }
    .tl-diff-modified rect.tl-block-rect { fill: #fed7aa; stroke: #f97316; stroke-width: 1.2px; }

    .merge-merged {
      margin-top: 10px;
    }

    /* --- Per-stop merge toggles --- */
    .merge-stop-toggles {
      margin-top: 12px;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .merge-stop-toggles-heading {
      font-size: 13px;
      font-weight: 600;
      color: #111827;
      margin-bottom: 2px;
    }
    .merge-stop-toggle {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 6px 10px;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: #f9fafb;
      font-size: 13px;
    }
    .merge-stop-toggle .stop-info {
      min-width: 120px;
      flex-shrink: 0;
    }
    .merge-stop-toggle .stop-info .stop-name {
      font-weight: 600;
      font-size: 12px;
    }
    .merge-stop-toggle .stop-info .stop-day {
      font-size: 11px;
      color: var(--muted);
    }
    .merge-stop-toggle .stop-options {
      display: flex;
      gap: 4px;
      flex-wrap: wrap;
      flex: 1;
    }
    .merge-stop-toggle .stop-option {
      display: flex;
      align-items: center;
      gap: 4px;
      padding: 3px 8px;
      border: 1px solid var(--border);
      border-radius: 6px;
      background: #fff;
      font-size: 12px;
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s;
    }
    .merge-stop-toggle .stop-option:has(input:checked) {
      border-color: #6366f1;
      background: #eef2ff;
      font-weight: 600;
    }
    .merge-stop-toggle .stop-option.opt-disabled {
      opacity: 0.35;
      cursor: not-allowed;
      text-decoration: line-through;
    }
    .merge-stop-toggle .stop-option input[type="radio"] {
      margin: 0;
      width: 12px;
      height: 12px;
    }
    .merge-stop-toggle .stop-option .opt-time {
      color: var(--muted);
      font-size: 11px;
    }

    @media (max-width: 900px) {
      .plan-diff-grid { grid-template-columns: 1fr; }
      .conflict-compare { grid-template-columns: 1fr; }
      .merge-stop-toggle { flex-direction: column; align-items: flex-start; }
    }
    @media (max-width: 640px) {
      .plan-preview-grid { flex-direction: column; }
      .plan-preview-col { max-height: 200px; }
      .diff-map-frame { height: 250px; }
      .merge-stop-toggle .stop-option {
        min-height: 44px;
        padding: 6px 10px;
      }
    }

    /* --- Feature 1: Inline field-level diffs --- */
    .field-changed {
      font-weight: 700;
      border-radius: 3px;
      padding: 1px 4px;
    }
    .field-changed-source {
      background: #dcfce7;
    }
    .field-changed-target {
      background: #dbeafe;
    }
    .field-unchanged {
      opacity: 0.5;
    }

    /* --- Feature 2: Unified diff toggle --- */
    .diff-view-toggle {
      display: inline-flex;
      gap: 0;
      border: 1px solid var(--border);
      border-radius: 6px;
      overflow: hidden;
      margin-left: 12px;
      vertical-align: middle;
    }
    .diff-view-toggle button {
      padding: 4px 12px;
      font-size: 12px;
      border: none;
      background: #f9fafb;
      cursor: pointer;
      color: #374151;
      transition: background 0.15s, color 0.15s;
    }
    .diff-view-toggle button.active {
      background: #6366f1;
      color: #fff;
      font-weight: 600;
    }
    .diff-view-toggle button:not(:last-child) {
      border-right: 1px solid var(--border);
    }
    .plan-diff-unified {
      display: none;
      margin-top: 8px;
    }
    .plan-diff-unified.visible {
      display: block;
    }
    .plan-diff-grid.hidden {
      display: none;
    }
    .unified-stop-label {
      display: inline-block;
      font-size: 10px;
      font-weight: 700;
      padding: 1px 6px;
      border-radius: 3px;
      margin-right: 4px;
      vertical-align: middle;
    }
    .unified-stop-label.source-label {
      background: #dcfce7;
      color: #065f46;
    }
    .unified-stop-label.target-label {
      background: #dbeafe;
      color: #1e40af;
    }
    .unified-day-section {
      margin-top: 8px;
    }
    .unified-day-title {
      font-weight: 600;
      font-size: 12px;
      color: #111827;
      margin-bottom: 4px;
    }
    .unified-stop-row {
      margin-left: 10px;
      margin-top: 2px;
      font-size: 13px;
    }

    /* --- Feature 3: Conflict count badge --- */
    .conflict-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: #f3f4f6;
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 4px 14px;
      font-size: 13px;
      color: #374151;
      margin-bottom: 10px;
    }
    .conflict-badge .badge-count {
      font-weight: 700;
      color: #6366f1;
    }
    .conflict-badge.all-resolved {
      background: #ecfdf5;
      border-color: #bbf7d0;
    }
    .conflict-badge.all-resolved .badge-count {
      color: #16a34a;
    }

    /* --- Feature 4: Merged plan preview card --- */
    .merged-preview-card {
      margin-top: 12px;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 10px;
      background: #f9fafb;
      max-height: 400px;
      overflow: auto;
      font-size: 13px;
    }
    .merged-preview-heading {
      font-size: 14px;
      font-weight: 700;
      margin: 0 0 8px;
      color: #111827;
    }

    @media (max-width: 900px) {
      .diff-view-toggle { margin-left: 0; margin-top: 6px; }
      .merged-preview-card { max-height: 300px; }
    }
    @media (max-width: 640px) {
      .merged-preview-card { max-height: 220px; }
    }

    /* --- High contrast --- */
    .high-contrast .diff-added { background: #064e3b; color: #f8f8f8; border-color: #16a34a; }
    .high-contrast .diff-removed { background: #450a0a; color: #f8f8f8; border-color: #ef4444; }
    .high-contrast .diff-modified { background: #451a03; color: #f8f8f8; border-color: #f97316; }
    .high-contrast .diff-map-frame { border: 1px solid #f97316; }
    .high-contrast .conflict-compare-card { background: #1a1a2e; border-color: #444; }
    .high-contrast .field-changed-source { background: #064e3b; color: #f8f8f8; }
    .high-contrast .field-changed-target { background: #1e3a5f; color: #f8f8f8; }
    .high-contrast .conflict-badge { background: #1a1a2e; border-color: #444; color: #e0e0e0; }
    .high-contrast .conflict-badge .badge-count { color: #a5b4fc; }
    .high-contrast .diff-view-toggle button { background: #1a1a2e; color: #e0e0e0; border-color: #444; }
    .high-contrast .diff-view-toggle button.active { background: #6366f1; color: #fff; }
    .high-contrast .merged-preview-card { background: #1a1a2e; border-color: #444; color: #e0e0e0; }
    .high-contrast .unified-stop-label.source-label { background: #064e3b; color: #f8f8f8; }
    .high-contrast .unified-stop-label.target-label { background: #1e3a5f; color: #f8f8f8; }
  </style>

  <div class="card">
    <form class="row" method="get" action="">
      <label>Source
        <select name="source">
          <% branches.forEach(b=>{ %>
            <option value="<%= b.name %>" <%= b.name===source?'selected':'' %>><%= b.name %></option>
          <% }) %>
        </select>
      </label>
      <label>Target
        <select name="target">
          <% branches.forEach(b=>{ %>
            <option value="<%= b.name %>" <%= b.name===target?'selected':'' %>><%= b.name %></option>
          <% }) %>
        </select>
      </label>
      <button class="btn">Check</button>
    </form>
  </div>

  <div class="card" style="margin-top:12px">
    <h2>Status</h2>

    <% if (!baseId) { %>
      <p class="time">
        Couldn't compute a common base commit for these branches, so a proper 3‑way merge isn't available.
        You can still compare the two plans below.
      </p>
    <% } else if (!conflicts.length) { %>
      <p>
        <span class="icon-inline" aria-hidden="true">
          <i class="fa-solid fa-circle-check"></i>
        </span>
        No merge conflicts detected. Review the plan comparison below, then merge into
        <strong><%= target %></strong>.
      </p>
      <form method="post"
            action="/api/repos/<%= repo.id %>/merge"
            onsubmit="return mergeDirect(event)">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" id="base" value="<%= baseId %>"/>
        <input type="hidden" id="ours" value="<%= oursId %>"/>
        <input type="hidden" id="theirs" value="<%= theirsId %>"/>
        <input type="hidden" id="targetBranch" value="<%= target %>"/>
        <button class="btn btn-primary">Merge now</button>
      </form>
    <% } else { %>
      <p>There are <strong><%= conflicts.length %></strong> conflicts. Resolve them below.</p>

      <form method="post"
            action="/ui/repos/<%= repo.id %>/merge-resolve"
            onsubmit="return submitResolutions()">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="baseId" value="<%= baseId %>"/>
        <input type="hidden" name="oursId" value="<%= oursId %>"/>
        <input type="hidden" name="theirsId" value="<%= theirsId %>"/>
        <input type="hidden" name="targetBranch" value="<%= target %>"/>
        <input type="hidden" id="resolutions" name="resolutions" />

        <ul class="list">
          <% conflicts.forEach((c,idx)=>{ %>
            <li>
              <% if (c.type==='file') { %>
                <div style="display:flex;align-items:center;justify-content:space-between">
                  <div><strong>File conflict:</strong> <code><%= c.path %></code></div>
                  <div class="row" style="margin:0">
                    <label><input type="radio" name="c<%= idx %>" value="base" checked /> Keep base</label>
                    <label><input type="radio" name="c<%= idx %>" value="ours" /> Use source</label>
                    <label><input type="radio" name="c<%= idx %>" value="theirs" /> Use target</label>
                  </div>
                </div>

                <div class="row" style="margin-top:8px;border-top:1px solid var(--border);padding-top:8px">
                  <div style="flex:1">
                    <div class="time">Source (ours)</div>
                    <pre class="code"><%= (c.ours||'').slice(0,20000) %></pre>
                  </div>
                  <div style="flex:1">
                    <div class="time">Target (theirs)</div>
                    <pre class="code"><%= (c.theirs||'').slice(0,20000) %></pre>
                  </div>
                </div>
              <% } else if (c.type==='plan-stop-time') { %>
                <div>
                  <strong>Stop time conflict:</strong>
                  day <code><%= c.dayId %></code>,
                  stop <code><%= c.stopId %></code>
                </div>
                <div class="row">
                  <label>
                    <input type="radio" name="c<%= idx %>" value="base" checked />
                    Keep base times
                    <span class="time">
                      (<%= c.base?.arrive || '??:??' %> → <%= c.base?.depart || '??:??' %>)
                    </span>
                  </label>
                  <label>
                    <input type="radio" name="c<%= idx %>" value="ours" />
                    Use source times
                    <span class="time">
                      (<%= c.ours?.arrive || '??:??' %> → <%= c.ours?.depart || '??:??' %>)
                    </span>
                  </label>
                  <label>
                    <input type="radio" name="c<%= idx %>" value="theirs" />
                    Use target times
                    <span class="time">
                      (<%= c.theirs?.arrive || '??:??' %> → <%= c.theirs?.depart || '??:??' %>)
                    </span>
                  </label>
                </div>

                <div class="conflict-compare">
                  <div class="conflict-compare-card">
                    <div class="label">Base</div>
                    <div><%= c.base?.arrive || '??:??' %> &rarr; <%= c.base?.depart || '??:??' %></div>
                  </div>
                  <div class="conflict-compare-card" style="background:#ecfdf3;border-color:#bbf7d0">
                    <div class="label">Source</div>
                    <div><%= c.ours?.arrive || '??:??' %> &rarr; <%= c.ours?.depart || '??:??' %></div>
                  </div>
                  <div class="conflict-compare-card" style="background:#eff6ff;border-color:#bfdbfe">
                    <div class="label">Target</div>
                    <div><%= c.theirs?.arrive || '??:??' %> &rarr; <%= c.theirs?.depart || '??:??' %></div>
                  </div>
                </div>
              <% } else if (c.type==='plan-stop-delete') { %>
                <div>
                  <strong>Stop deleted vs edited:</strong>
                  day <code><%= c.dayId %></code>,
                  stop <code><%= c.stopId %></code>
                </div>
                <p class="time">
                  One branch deleted this stop while the other edited it. Choose what to keep.
                </p>

                <div class="row">
                  <label>
                    <input type="radio" name="c<%= idx %>" value="base" checked />
                    Keep base stop
                    <span class="time">
                      (<%= c.base?.name || 'Untitled' %>
                      <% if (c.base?.arrive || c.base?.depart) { %>
                        • <%= c.base?.arrive || '??:??' %> → <%= c.base?.depart || '??:??' %>
                      <% } %>)
                    </span>
                  </label>

                  <label>
                    <input type="radio" name="c<%= idx %>" value="ours" />
                    <%= c.ours ? 'Use source version' : 'Delete (source removed it)' %>
                    <span class="time">
                      <% if (c.ours) { %>
                        (<%= c.ours?.name || 'Untitled' %>
                        <% if (c.ours?.arrive || c.ours?.depart) { %>
                          • <%= c.ours?.arrive || '??:??' %> → <%= c.ours?.depart || '??:??' %>
                        <% } %>)
                      <% } %>
                    </span>
                  </label>

                  <label>
                    <input type="radio" name="c<%= idx %>" value="theirs" />
                    <%= c.theirs ? 'Use target version' : 'Delete (target removed it)' %>
                    <span class="time">
                      <% if (c.theirs) { %>
                        (<%= c.theirs?.name || 'Untitled' %>
                        <% if (c.theirs?.arrive || c.theirs?.depart) { %>
                          • <%= c.theirs?.arrive || '??:??' %> → <%= c.theirs?.depart || '??:??' %>
                        <% } %>)
                      <% } %>
                    </span>
                  </label>
                </div>

                <div class="conflict-compare">
                  <div class="conflict-compare-card">
                    <div class="label">Base</div>
                    <div><%= c.base?.name || '—' %></div>
                    <div class="time"><%= c.base?.arrive || '??:??' %> &rarr; <%= c.base?.depart || '??:??' %></div>
                  </div>
                  <div class="conflict-compare-card" style="background:#ecfdf3;border-color:#bbf7d0">
                    <div class="label">Source</div>
                    <% if (!c.ours) { %>
                      <div style="color:#ef4444">Deleted</div>
                    <% } else { %>
                      <div><%= c.ours?.name || '—' %></div>
                      <div class="time"><%= c.ours?.arrive || '??:??' %> &rarr; <%= c.ours?.depart || '??:??' %></div>
                    <% } %>
                  </div>
                  <div class="conflict-compare-card" style="background:#eff6ff;border-color:#bfdbfe">
                    <div class="label">Target</div>
                    <% if (!c.theirs) { %>
                      <div style="color:#ef4444">Deleted</div>
                    <% } else { %>
                      <div><%= c.theirs?.name || '—' %></div>
                      <div class="time"><%= c.theirs?.arrive || '??:??' %> &rarr; <%= c.theirs?.depart || '??:??' %></div>
                    <% } %>
                  </div>
                </div>
              <% } else if (c.type==='plan-stop-field') { %>
                <div>
                  <strong>Stop field conflict:</strong>
                  day <code><%= c.dayId %></code>,
                  stop <code><%= c.stopId %></code>
                </div>
                <p class="time">
                  Both branches changed
                  <strong><%= (c.fields || []).join(', ') %></strong>
                  to different values. Choose which version to keep.
                </p>
                <div class="row">
                  <label>
                    <input type="radio" name="c<%= idx %>" value="base" checked />
                    Keep base
                  </label>
                  <label>
                    <input type="radio" name="c<%= idx %>" value="ours" />
                    Use source
                  </label>
                  <label>
                    <input type="radio" name="c<%= idx %>" value="theirs" />
                    Use target
                  </label>
                </div>

                <div class="conflict-compare">
                  <div class="conflict-compare-card">
                    <div class="label">Base</div>
                    <div><%= c.base?.name || '—' %></div>
                    <% (c.fields || []).forEach(function(f){ %>
                      <div class="time"><%= f %>: <%= c.base?.[f] ?? '—' %></div>
                    <% }) %>
                  </div>
                  <div class="conflict-compare-card" style="background:#ecfdf3;border-color:#bbf7d0">
                    <div class="label">Source</div>
                    <div><%= c.ours?.name || '—' %></div>
                    <% (c.fields || []).forEach(function(f){ %>
                      <% var srcVal = String(c.ours?.[f] ?? '—'); var baseVal = String(c.base?.[f] ?? '—'); var srcChanged = srcVal !== baseVal; %>
                      <div class="time <%= srcChanged ? 'field-changed field-changed-source' : 'field-unchanged' %>"><%= f %>: <%= c.ours?.[f] ?? '—' %></div>
                    <% }) %>
                  </div>
                  <div class="conflict-compare-card" style="background:#eff6ff;border-color:#bfdbfe">
                    <div class="label">Target</div>
                    <div><%= c.theirs?.name || '—' %></div>
                    <% (c.fields || []).forEach(function(f){ %>
                      <% var tgtVal = String(c.theirs?.[f] ?? '—'); var baseValT = String(c.base?.[f] ?? '—'); var tgtChanged = tgtVal !== baseValT; %>
                      <div class="time <%= tgtChanged ? 'field-changed field-changed-target' : 'field-unchanged' %>"><%= f %>: <%= c.theirs?.[f] ?? '—' %></div>
                    <% }) %>
                  </div>
                </div>
              <% } else if (c.type==='plan-whole') { %>
                <div>
                  <strong>Itinerary conflict:</strong>
                  both source and target changed the overall trip layout.
                </div>
                <p class="time">
                  Choose which full plan to keep on the target branch. This will replace days and stops.
                </p>
                <div class="row">
                  <label><input type="radio" name="c<%= idx %>" value="base" checked /> Keep base plan</label>
                  <label><input type="radio" name="c<%= idx %>" value="ours" /> Use source plan</label>
                  <label><input type="radio" name="c<%= idx %>" value="theirs" /> Use target plan</label>
                </div>

                <div class="plan-preview-grid" style="margin-top:8px">
                  <div class="plan-preview-col">
                    <div class="time"><strong>Base</strong></div>
                    <% const pB = c.base; %>
                    <% if (!pB || !Array.isArray(pB.days) || !pB.days.length) { %>
                      <div class="plan-preview-empty">No plan</div>
                    <% } else { %>
                      <% pB.days.forEach(function(d){ %>
                        <div class="plan-preview-day">
                          <div class="plan-preview-day-title"><%= d.date || d.id %></div>
                          <% if (!Array.isArray(d.stops) || !d.stops.length) { %>
                            <div class="plan-preview-empty">No stops</div>
                          <% } else { %>
                            <% d.stops.forEach(function(s){ %>
                              <% if (s) { %>
                                <div class="plan-preview-stop">
                                  <strong><%= s.name || 'Untitled stop' %></strong>
                                  <% if (s.arrive || s.depart) { %>
                                    <span class="time">
                                      <%= s.arrive || '??:??' %> → <%= s.depart || '??:??' %>
                                    </span>
                                  <% } %>
                                </div>
                              <% } %>
                            <% }); %>
                          <% } %>
                        </div>
                      <% }); %>
                    <% } %>
                  </div>

                  <div class="plan-preview-col">
                    <div class="time"><strong>Source</strong></div>
                    <% const pO = c.ours; %>
                    <% if (!pO || !Array.isArray(pO.days) || !pO.days.length) { %>
                      <div class="plan-preview-empty">No plan</div>
                    <% } else { %>
                      <% pO.days.forEach(function(d){ %>
                        <div class="plan-preview-day">
                          <div class="plan-preview-day-title"><%= d.date || d.id %></div>
                          <% if (!Array.isArray(d.stops) || !d.stops.length) { %>
                            <div class="plan-preview-empty">No stops</div>
                          <% } else { %>
                            <% d.stops.forEach(function(s){ %>
                              <% if (s) { %>
                                <div class="plan-preview-stop">
                                  <strong><%= s.name || 'Untitled stop' %></strong>
                                  <% if (s.arrive || s.depart) { %>
                                    <span class="time">
                                      <%= s.arrive || '??:??' %> → <%= s.depart || '??:??' %>
                                    </span>
                                  <% } %>
                                </div>
                              <% } %>
                            <% }); %>
                          <% } %>
                        </div>
                      <% }); %>
                    <% } %>
                  </div>

                  <div class="plan-preview-col">
                    <div class="time"><strong>Target</strong></div>
                    <% const pT = c.theirs; %>
                    <% if (!pT || !Array.isArray(pT.days) || !pT.days.length) { %>
                      <div class="plan-preview-empty">No plan</div>
                    <% } else { %>
                      <% pT.days.forEach(function(d){ %>
                        <div class="plan-preview-day">
                          <div class="plan-preview-day-title"><%= d.date || d.id %></div>
                          <% if (!Array.isArray(d.stops) || !d.stops.length) { %>
                            <div class="plan-preview-empty">No stops</div>
                          <% } else { %>
                            <% d.stops.forEach(function(s){ %>
                              <% if (s) { %>
                                <div class="plan-preview-stop">
                                  <strong><%= s.name || 'Untitled stop' %></strong>
                                  <% if (s.arrive || s.depart) { %>
                                    <span class="time">
                                      <%= s.arrive || '??:??' %> → <%= s.depart || '??:??' %>
                                    </span>
                                  <% } %>
                                </div>
                              <% } %>
                            <% }); %>
                          <% } %>
                        </div>
                      <% }); %>
                    <% } %>
                  </div>
                </div>
              <% } %>
              <input type="hidden" id="meta<%= idx %>" value='<%- JSON.stringify(c) %>' />
            </li>
          <% }) %>
        </ul>

        <!-- Feature 4: Merged plan preview -->
        <div style="margin-top:16px">
          <h3 class="merged-preview-heading">Merged plan preview</h3>
          <p class="time">Updates live as you change conflict resolutions and per-stop toggles.</p>
          <div class="merged-preview-card" id="mergedPlanPreview">
            <div class="plan-preview-empty">Calculating merged plan...</div>
          </div>
        </div>

        <!-- Feature 3: Conflict count badge + merge button -->
        <div class="section-actions" style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
          <div class="conflict-badge" id="conflictBadge">
            <span class="badge-count" id="conflictBadgeCount">0</span> / <span id="conflictBadgeTotal">0</span> resolved
          </div>
          <button class="btn btn-primary" type="submit">
            Apply resolutions &amp; Merge
          </button>
        </div>
      </form>
    <% } %>

    <%
      /* ---- Diff computation ---- */
      var baseStopIndex = {};
      if (basePlan && Array.isArray(basePlan.days)) {
        basePlan.days.forEach(function(d) {
          if (!d || !Array.isArray(d.stops)) return;
          d.stops.forEach(function(s) {
            if (!s) return;
            baseStopIndex[d.id + '::' + s.id] = s;
          });
        });
      }

      function computeDiffStatus(plan) {
        var status = {};
        if (!plan || !Array.isArray(plan.days)) return status;
        plan.days.forEach(function(d) {
          if (!d || !Array.isArray(d.stops)) return;
          d.stops.forEach(function(s) {
            if (!s) return;
            var key = d.id + '::' + s.id;
            var bs = baseStopIndex[key];
            if (!bs) {
              status[key] = 'added';
            } else if (bs.arrive !== s.arrive || bs.depart !== s.depart) {
              status[key] = 'modified';
            } else {
              status[key] = 'unchanged';
            }
          });
        });
        Object.keys(baseStopIndex).forEach(function(key) {
          if (!(key in status)) status[key] = 'removed';
        });
        return status;
      }

      var ourDiffStatus = computeDiffStatus(ourPlan);
      var theirDiffStatus = computeDiffStatus(theirPlan);

      function diffClass(statusMap, dayId, stopId) {
        var key = dayId + '::' + stopId;
        var st = statusMap[key];
        if (st === 'added') return 'diff-added';
        if (st === 'removed') return 'diff-removed';
        if (st === 'modified') return 'diff-modified';
        return '';
      }
    %>

    <% if (basePlan || ourPlan || theirPlan) { %>
      <h3 style="margin-top:16px">Plan comparison
        <span class="diff-view-toggle" id="diffViewToggle">
          <button type="button" data-view="side" class="active">Side-by-side</button>
          <button type="button" data-view="unified">Unified</button>
        </span>
      </h3>
      <p class="time">
        Diff vs the common ancestor (base).
        Source is <strong><%= source %></strong>; Target is <strong><%= target %></strong>.
      </p>

      <div class="diff-legend">
        <span class="diff-legend-item">
          <span class="diff-legend-swatch" style="background:#ecfdf3;border:1px solid #16a34a"></span> Added
        </span>
        <span class="diff-legend-item">
          <span class="diff-legend-swatch" style="background:#fef2f2;border:1px solid #ef4444"></span> Removed
        </span>
        <span class="diff-legend-item">
          <span class="diff-legend-swatch" style="background:#fffbeb;border:1px solid #f97316"></span> Time changed
        </span>
        <span class="diff-legend-item">
          <span class="diff-legend-swatch" style="background:#fff;border:1px solid var(--border)"></span> Unchanged
        </span>
      </div>

      <div class="plan-diff-grid">
        <!-- Source column -->
        <div class="plan-preview-col">
          <div class="plan-diff-col-heading">
            Source <span class="branch-label">(<%= source %>)</span>
          </div>
          <% if (!ourPlan || !Array.isArray(ourPlan.days) || !ourPlan.days.length) { %>
            <div class="plan-preview-empty">No plan</div>
          <% } else { %>
            <% ourPlan.days.forEach(function(d) { %>
              <div class="plan-preview-day">
                <div class="plan-preview-day-title"><%= d.date || d.id %></div>
                <% if (!Array.isArray(d.stops) || !d.stops.length) { %>
                  <div class="plan-preview-empty">No stops</div>
                <% } else { %>
                  <% d.stops.forEach(function(s) { %>
                    <% if (s) { %>
                      <div class="plan-preview-stop <%= diffClass(ourDiffStatus, d.id, s.id) %>">
                        <strong><%= s.name || 'Untitled stop' %></strong>
                        <% if (s.arrive || s.depart) { %>
                          <span class="time">
                            <%= s.arrive || '??:??' %> &rarr; <%= s.depart || '??:??' %>
                          </span>
                        <% } %>
                      </div>
                    <% } %>
                  <% }); %>
                <% } %>
                <%
                  /* Render removed stops (in base but missing from source for this day) */
                  if (basePlan && Array.isArray(basePlan.days)) {
                    var baseDay = basePlan.days.find(function(bd) { return bd.id === d.id; });
                    if (baseDay && Array.isArray(baseDay.stops)) {
                      baseDay.stops.forEach(function(bs) {
                        if (!bs) return;
                        var key = d.id + '::' + bs.id;
                        if (ourDiffStatus[key] === 'removed') { %>
                          <div class="plan-preview-stop diff-removed">
                            <strong><%= bs.name || 'Untitled stop' %></strong>
                            <% if (bs.arrive || bs.depart) { %>
                              <span class="time">
                                <%= bs.arrive || '??:??' %> &rarr; <%= bs.depart || '??:??' %>
                              </span>
                            <% } %>
                          </div>
                <%      }
                      });
                    }
                  }
                %>
              </div>
            <% }); %>
          <% } %>
        </div>

        <!-- Target column -->
        <div class="plan-preview-col">
          <div class="plan-diff-col-heading">
            Target <span class="branch-label">(<%= target %>)</span>
          </div>
          <% if (!theirPlan || !Array.isArray(theirPlan.days) || !theirPlan.days.length) { %>
            <div class="plan-preview-empty">No plan</div>
          <% } else { %>
            <% theirPlan.days.forEach(function(d) { %>
              <div class="plan-preview-day">
                <div class="plan-preview-day-title"><%= d.date || d.id %></div>
                <% if (!Array.isArray(d.stops) || !d.stops.length) { %>
                  <div class="plan-preview-empty">No stops</div>
                <% } else { %>
                  <% d.stops.forEach(function(s) { %>
                    <% if (s) { %>
                      <div class="plan-preview-stop <%= diffClass(theirDiffStatus, d.id, s.id) %>">
                        <strong><%= s.name || 'Untitled stop' %></strong>
                        <% if (s.arrive || s.depart) { %>
                          <span class="time">
                            <%= s.arrive || '??:??' %> &rarr; <%= s.depart || '??:??' %>
                          </span>
                        <% } %>
                      </div>
                    <% } %>
                  <% }); %>
                <% } %>
                <%
                  if (basePlan && Array.isArray(basePlan.days)) {
                    var baseDayT = basePlan.days.find(function(bd) { return bd.id === d.id; });
                    if (baseDayT && Array.isArray(baseDayT.stops)) {
                      baseDayT.stops.forEach(function(bs) {
                        if (!bs) return;
                        var key = d.id + '::' + bs.id;
                        if (theirDiffStatus[key] === 'removed') { %>
                          <div class="plan-preview-stop diff-removed">
                            <strong><%= bs.name || 'Untitled stop' %></strong>
                            <% if (bs.arrive || bs.depart) { %>
                              <span class="time">
                                <%= bs.arrive || '??:??' %> &rarr; <%= bs.depart || '??:??' %>
                              </span>
                            <% } %>
                          </div>
                <%      }
                      });
                    }
                  }
                %>
              </div>
            <% }); %>
          <% } %>
        </div>
      </div>

      <!-- Unified diff view (hidden by default on desktop) -->
      <div class="plan-diff-unified" id="planDiffUnified">
        <div class="plan-preview-col" style="max-height:400px">
          <%
            /* Collect all unique day IDs from both plans */
            var allDayIds = [];
            var dayDateMap = {};
            function collectDays(plan) {
              if (!plan || !Array.isArray(plan.days)) return;
              plan.days.forEach(function(d) {
                if (!d) return;
                if (allDayIds.indexOf(d.id) === -1) allDayIds.push(d.id);
                if (!dayDateMap[d.id]) dayDateMap[d.id] = d.date || d.id;
              });
            }
            collectDays(ourPlan);
            collectDays(theirPlan);
          %>
          <% allDayIds.forEach(function(dayId) { %>
            <div class="unified-day-section">
              <div class="unified-day-title"><%= dayDateMap[dayId] %></div>
              <%
                var ourDay = ourPlan && Array.isArray(ourPlan.days) ? ourPlan.days.find(function(d){ return d.id === dayId; }) : null;
                var theirDay = theirPlan && Array.isArray(theirPlan.days) ? theirPlan.days.find(function(d){ return d.id === dayId; }) : null;
                var ourStops = (ourDay && Array.isArray(ourDay.stops)) ? ourDay.stops : [];
                var theirStops = (theirDay && Array.isArray(theirDay.stops)) ? theirDay.stops : [];
              %>
              <% ourStops.forEach(function(s) { if (!s) return; %>
                <div class="unified-stop-row <%= diffClass(ourDiffStatus, dayId, s.id) %>">
                  <span class="unified-stop-label source-label">Source</span>
                  <strong><%= s.name || 'Untitled stop' %></strong>
                  <% if (s.arrive || s.depart) { %>
                    <span class="time"><%= s.arrive || '??:??' %> &rarr; <%= s.depart || '??:??' %></span>
                  <% } %>
                </div>
              <% }); %>
              <% theirStops.forEach(function(s) { if (!s) return; %>
                <div class="unified-stop-row <%= diffClass(theirDiffStatus, dayId, s.id) %>">
                  <span class="unified-stop-label target-label">Target</span>
                  <strong><%= s.name || 'Untitled stop' %></strong>
                  <% if (s.arrive || s.depart) { %>
                    <span class="time"><%= s.arrive || '??:??' %> &rarr; <%= s.depart || '??:??' %></span>
                  <% } %>
                </div>
              <% }); %>
            </div>
          <% }); %>
        </div>
      </div>

      <!-- Base as collapsible reference -->
      <details class="plan-base-ref">
        <summary>
          <i class="fa-solid fa-code-branch" aria-hidden="true"></i>
          Show base plan (common ancestor)
        </summary>
        <div class="plan-preview-col" style="margin-top:8px;max-height:none">
          <% if (!basePlan || !Array.isArray(basePlan.days) || !basePlan.days.length) { %>
            <div class="plan-preview-empty">No plan</div>
          <% } else { %>
            <% basePlan.days.forEach(function(d){ %>
              <div class="plan-preview-day">
                <div class="plan-preview-day-title"><%= d.date || d.id %></div>
                <% if (!Array.isArray(d.stops) || !d.stops.length) { %>
                  <div class="plan-preview-empty">No stops</div>
                <% } else { %>
                  <% d.stops.forEach(function(s){ %>
                    <% if (s) { %>
                      <div class="plan-preview-stop">
                        <strong><%= s.name || 'Untitled stop' %></strong>
                        <% if (s.arrive || s.depart) { %>
                          <span class="time">
                            <%= s.arrive || '??:??' %> → <%= s.depart || '??:??' %>
                          </span>
                        <% } %>
                      </div>
                    <% } %>
                  <% }); %>
                <% } %>
              </div>
            <% }); %>
          <% } %>
        </div>
      </details>
    <% } %>
  </div>

  <!-- Diff map -->
  <div class="card" style="margin-top:12px">
    <h2>Diff map</h2>
    <p class="time">All stops color-coded by change status. Hover for details.</p>
    <div class="diff-legend" style="margin-bottom:8px">
      <span class="diff-legend-item">
        <span class="diff-legend-swatch" style="background:#16a34a"></span> Added
      </span>
      <span class="diff-legend-item">
        <span class="diff-legend-swatch" style="background:#ef4444"></span> Removed
      </span>
      <span class="diff-legend-item">
        <span class="diff-legend-swatch" style="background:#f97316"></span> Time changed
      </span>
      <span class="diff-legend-item">
        <span class="diff-legend-swatch" style="background:#9ca3af"></span> Unchanged
      </span>
    </div>
    <div class="diff-map-frame">
      <div id="diffMap" style="width:100%;height:100%"></div>
    </div>
  </div>

  <div class="card" style="margin-top:12px">
    <h2>Timeline compare</h2>
    <div class="merge-timeline-grid">
      <div class="merge-timeline-col">
        <div class="merge-timeline-title">Base</div>
        <div id="timelineBase"></div>
      </div>
      <div class="merge-timeline-col">
        <div class="merge-timeline-title">Source (<%= source %>)</div>
        <div id="timelineOurs"></div>
      </div>
      <div class="merge-timeline-col">
        <div class="merge-timeline-title">Target (<%= target %>)</div>
        <div id="timelineTheirs"></div>
      </div>
    </div>
  </div>

  <div class="card merge-merged">
    <h2>Merged timeline preview</h2>
    <p class="time">Pick which version of each changed stop to include. Unchanged stops are kept automatically.</p>
    <div id="mergeStopToggles"></div>
    <div id="timelineMerged" style="margin-top:10px"></div>
  </div>
</section>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
const basePlan = <%- JSON.stringify(basePlan || null) %>;
const ourPlan = <%- JSON.stringify(ourPlan || null) %>;
const theirPlan = <%- JSON.stringify(theirPlan || null) %>;
const mergedPlanBase = <%- JSON.stringify(mergedPlan || null) %>;
const conflictMeta = <%- JSON.stringify(conflicts || []) %>;

/* Build client-side diff status maps (mirrors the EJS scriptlet logic) */
function buildBaseIndex(plan) {
  const idx = {};
  if (plan && Array.isArray(plan.days)) {
    plan.days.forEach(d => {
      if (!d || !Array.isArray(d.stops)) return;
      d.stops.forEach(s => { if (s) idx[d.id + '::' + s.id] = s; });
    });
  }
  return idx;
}
function buildDiffMap(plan, baseIdx) {
  const status = {};
  if (!plan || !Array.isArray(plan.days)) return status;
  plan.days.forEach(d => {
    if (!d || !Array.isArray(d.stops)) return;
    d.stops.forEach(s => {
      if (!s) return;
      const key = d.id + '::' + s.id;
      const bs = baseIdx[key];
      if (!bs) status[key] = 'added';
      else if (bs.arrive !== s.arrive || bs.depart !== s.depart) status[key] = 'modified';
      else status[key] = 'unchanged';
    });
  });
  Object.keys(baseIdx).forEach(key => { if (!(key in status)) status[key] = 'removed'; });
  return status;
}
const _baseIdx = buildBaseIndex(basePlan);
const ourDiffMap = buildDiffMap(ourPlan, _baseIdx);
const theirDiffMap = buildDiffMap(theirPlan, _baseIdx);

async function mergeDirect(e){
  e.preventDefault();

  /* Check if user changed any per-stop toggles from auto-defaults */
  const toggleDecs = typeof collectToggleDecisions === 'function' ? collectToggleDecisions() : [];
  const hasOverrides = toggleDecs.some(d => {
    const key = d.dayId + '::' + d.stopId;
    return _toggleDefaults[key] !== d.choice;
  });

  if (hasOverrides) {
    /* User customised stops — use the resolve flow instead of direct merge */
    const resolutions = JSON.stringify(toggleDecs);
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = '/ui/repos/<%= repo.id %>/merge-resolve';
    const fields = {
      _csrf: '<%= csrfToken %>',
      baseId: document.getElementById('base').value,
      oursId: document.getElementById('ours').value,
      theirsId: document.getElementById('theirs').value,
      targetBranch: document.getElementById('targetBranch').value,
      resolutions: resolutions,
    };
    Object.keys(fields).forEach(k => {
      const inp = document.createElement('input');
      inp.type = 'hidden'; inp.name = k; inp.value = fields[k];
      form.appendChild(inp);
    });
    document.body.appendChild(form);
    form.submit();
    return;
  }

  const body = {
    base: document.getElementById('base').value,
    ours: document.getElementById('ours').value,
    theirs: document.getElementById('theirs').value,
    targetBranch: document.getElementById('targetBranch').value,
    expectedTargetHead: document.getElementById('theirs').value,
    author: 'web'
  };
  const r = await fetch('/api/repos/<%= repo.id %>/merge', {
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body: JSON.stringify(body)
  });
  if (r.ok) {
    window.location.href = '/ui/repos/<%= repo.id %>';
  } else {
    const j = await r.json().catch(()=>({}));
    showToast('Merge failed: ' + (j.error || 'conflicts occurred'), 'error');
    window.location.reload();
  }
}

function submitResolutions(){
  const metas = document.querySelectorAll('input[id^="meta"]');
  const res = [];
  metas.forEach((m, i)=>{
    const chosen = document.querySelector(`input[name="c${i}"]:checked`);
    const meta = JSON.parse(m.value);
    res.push({ ...meta, choice: chosen ? chosen.value : 'base' });
  });
  /* Append per-stop toggle decisions */
  const toggleDecs = typeof collectToggleDecisions === 'function' ? collectToggleDecisions() : [];
  toggleDecs.forEach(d => res.push(d));
  document.getElementById('resolutions').value = JSON.stringify(res);
  return true;
}

function shortName(name) {
  const label = String(name || '').trim();
  if (!label) return '';
  const commaIdx = label.indexOf(',');
  return commaIdx === -1 ? label : label.slice(0, commaIdx);
}

function toMin(t) {
  const parts = String(t || '').split(':').map(Number);
  if (parts.length < 2 || Number.isNaN(parts[0]) || Number.isNaN(parts[1])) return null;
  return (parts[0] || 0) * 60 + (parts[1] || 0);
}

function renderTimeline(container, plan, conflictSet, diffMap) {
  if (!container) return;
  container.innerHTML = '';
  if (!plan || !Array.isArray(plan.days) || !plan.days.length) {
    container.innerHTML = '<div class="plan-preview-empty">No plan</div>';
    return;
  }

  const actStart = 8 * 60;
  const actEnd = 22 * 60;
  const span = actEnd - actStart;

  plan.days.forEach((d) => {
    const dayWrap = document.createElement('div');
    dayWrap.className = 'merge-day';
    const title = document.createElement('div');
    title.className = 'merge-day-title';
    title.textContent = d.date || d.id || 'Day';
    dayWrap.appendChild(title);

    const tl = document.createElement('div');
    tl.className = 'merge-timeline';
    const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    svg.setAttribute('viewBox', '0 0 1000 120');
    svg.setAttribute('aria-label', 'timeline');

    const bg = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
    bg.setAttribute('x', '0');
    bg.setAttribute('y', '26');
    bg.setAttribute('width', '1000');
    bg.setAttribute('height', '28');
    bg.setAttribute('fill', '#ffffff');
    bg.setAttribute('stroke', '#e0e0e6');
    svg.appendChild(bg);

    for (let h = 8; h <= 22; h++) {
      const x = ((h * 60 - actStart) / span) * 1000;
      const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
      line.setAttribute('x1', String(x));
      line.setAttribute('y1', '26');
      line.setAttribute('x2', String(x));
      line.setAttribute('y2', '54');
      line.setAttribute('stroke', '#e5e7eb');
      svg.appendChild(line);

      const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      text.setAttribute('x', String(x + 4));
      text.setAttribute('y', '20');
      text.setAttribute('font-size', '10');
      text.setAttribute('fill', '#6b7280');
      text.textContent = `${h}:00`;
      svg.appendChild(text);
    }

    const stops = Array.isArray(d.stops) ? d.stops : [];
    stops.forEach((s) => {
      const a = toMin(s.arrive);
      const b = toMin(s.depart);
      if (a == null || b == null) return;
      let left = ((a - actStart) / span) * 1000;
      let width = Math.max(8, ((b - a) / span) * 1000);
      if (left < 0) { width = Math.max(8, width + left); left = 0; }
      if (left + width > 1000) { width = Math.max(8, 1000 - left); }
      if (left >= 1000) return;
      const labelYOffset = (Math.floor(left / 50) % 2) ? 22 : 38;
      const labelY = 68 + labelYOffset;

      const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
      const stopKey = `${d.id}::${s.id}`;
      let cls = 'tl-block';
      if (conflictSet && conflictSet.has(stopKey)) cls += ' merge-conflict';
      if (diffMap) {
        const ds = diffMap[stopKey];
        if (ds === 'added') cls += ' tl-diff-added';
        else if (ds === 'removed') cls += ' tl-diff-removed';
        else if (ds === 'modified') cls += ' tl-diff-modified';
      }
      g.setAttribute('class', cls);

      const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
      rect.setAttribute('class', 'tl-block-rect');
      rect.setAttribute('x', String(left));
      rect.setAttribute('y', '30');
      rect.setAttribute('width', String(width));
      rect.setAttribute('height', '20');
      rect.setAttribute('rx', '6');
      g.appendChild(rect);

      const leader = document.createElementNS('http://www.w3.org/2000/svg', 'line');
      leader.setAttribute('class', 'tl-leader');
      leader.setAttribute('x1', String(left + 6));
      leader.setAttribute('y1', '52');
      leader.setAttribute('x2', String(left + 6));
      leader.setAttribute('y2', String(labelY - 10));
      leader.setAttribute('stroke', '#9ca3af');
      leader.setAttribute('stroke-width', '1');
      leader.setAttribute('stroke-dasharray', '2,2');
      g.appendChild(leader);

      const label = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      label.setAttribute('class', 'tl-label');
      label.setAttribute('x', String(left + 6));
      label.setAttribute('y', String(labelY));
      label.setAttribute('font-size', '10');
      label.setAttribute('fill', '#111');
      label.textContent = shortName(s.name);
      g.appendChild(label);

      svg.appendChild(g);
    });

    tl.appendChild(svg);
    dayWrap.appendChild(tl);
    container.appendChild(dayWrap);
  });
}

function clonePlan(plan) {
  return plan ? JSON.parse(JSON.stringify(plan)) : null;
}

function applyResolutions() {
  const metas = document.querySelectorAll('input[id^="meta"]');
  const res = [];
  metas.forEach((m, i) => {
    const chosen = document.querySelector(`input[name="c${i}"]:checked`);
    const meta = JSON.parse(m.value);
    res.push({ ...meta, choice: chosen ? chosen.value : 'base' });
  });

  let merged = clonePlan(mergedPlanBase);
  if (!merged) return null;

  const whole = res.find((r) => r.type === 'plan-whole' && r.choice && r.choice !== 'base');
  if (whole) {
    if (whole.choice === 'ours') return clonePlan(ourPlan);
    if (whole.choice === 'theirs') return clonePlan(theirPlan);
    return clonePlan(basePlan);
  }

  res.forEach((r) => {
    if (r.type !== 'plan-stop-time') return;
    const pick =
      r.choice === 'ours' ? ourPlan :
      r.choice === 'theirs' ? theirPlan :
      basePlan;
    if (!pick || !pick.days) return;
    const pd = pick.days.find((d) => d.id === r.dayId);
    const ps = pd ? (pd.stops || []).find((s) => s.id === r.stopId) : null;
    if (!ps) return;
    const md = merged.days?.find((d) => d.id === r.dayId);
    const ms = md ? (md.stops || []).find((s) => s.id === r.stopId) : null;
    if (ms) {
      ms.arrive = ps.arrive;
      ms.depart = ps.depart;
    }
  });

  res.forEach((r) => {
    if (r.type !== 'plan-stop-delete') return;

    const pick =
      r.choice === 'ours' ? ourPlan :
      r.choice === 'theirs' ? theirPlan :
      basePlan;

    const pd = pick?.days?.find((d) => d.id === r.dayId);
    const ps = pd ? (pd.stops || []).find((s) => s && s.id === r.stopId) : null;

    const md = merged?.days?.find((d) => d.id === r.dayId);
    if (!md) return;

    const idx = (md.stops || []).findIndex((s) => s && s.id === r.stopId);
    if (idx < 0) return;

    if (ps) {
      md.stops[idx] = JSON.parse(JSON.stringify(ps));
    } else {
      md.stops.splice(idx, 1);
    }
  });

  return merged;
}

const conflictSet = new Set(
  conflictMeta
    .filter((c) => c.type === 'plan-stop-time' || c.type === 'plan-stop-delete')
    .map((c) => `${c.dayId}::${c.stopId}`)
);

/* ---- Per-stop merge toggles ---- */

/* Collect all unique dayId::stopId keys with their diff status */
const _allStopKeys = {};
function _indexPlanKeys(plan, label) {
  if (!plan || !Array.isArray(plan.days)) return;
  plan.days.forEach(d => {
    if (!d || !Array.isArray(d.stops)) return;
    d.stops.forEach(s => {
      if (!s) return;
      const key = d.id + '::' + s.id;
      if (!_allStopKeys[key]) _allStopKeys[key] = { dayId: d.id, stopId: s.id, dayDate: d.date || d.id };
      _allStopKeys[key][label] = s;
    });
  });
}
_indexPlanKeys(basePlan, 'base');
_indexPlanKeys(ourPlan, 'ours');
_indexPlanKeys(theirPlan, 'theirs');

/* Filter to only stops that differ from base */
const _differingStops = Object.keys(_allStopKeys).filter(key => {
  const st = ourDiffMap[key] || theirDiffMap[key];
  return st && st !== 'unchanged';
}).map(key => _allStopKeys[key]);

/* Determine auto-default choice for each differing stop */
function _autoDefault(info) {
  const key = info.dayId + '::' + info.stopId;
  const ourSt = ourDiffMap[key];
  const theirSt = theirDiffMap[key];
  // If it's a conflict (both changed), default to ours
  if (ourSt && ourSt !== 'unchanged' && theirSt && theirSt !== 'unchanged') return 'ours';
  // Only source changed
  if (ourSt && ourSt !== 'unchanged') return 'ours';
  // Only target changed
  if (theirSt && theirSt !== 'unchanged') return 'theirs';
  return 'base';
}

/* Store the defaults so we can detect user overrides */
const _toggleDefaults = {};
_differingStops.forEach(info => {
  const key = info.dayId + '::' + info.stopId;
  _toggleDefaults[key] = _autoDefault(info);
});

function renderMergeToggles() {
  const container = document.getElementById('mergeStopToggles');
  if (!container) return;
  container.innerHTML = '';

  if (!_differingStops.length) {
    container.innerHTML = '<div class="plan-preview-empty">No differing stops — merge is clean.</div>';
    return;
  }

  const heading = document.createElement('div');
  heading.className = 'merge-stop-toggles-heading';
  heading.textContent = 'Per-stop version picker (' + _differingStops.length + ' changed)';
  container.appendChild(heading);

  const list = document.createElement('div');
  list.className = 'merge-stop-toggles';

  /* Group by day */
  const byDay = {};
  _differingStops.forEach(info => {
    if (!byDay[info.dayId]) byDay[info.dayId] = { date: info.dayDate, stops: [] };
    byDay[info.dayId].stops.push(info);
  });

  Object.keys(byDay).forEach(dayId => {
    const dayGroup = byDay[dayId];

    dayGroup.stops.forEach(info => {
      const key = info.dayId + '::' + info.stopId;
      const row = document.createElement('div');
      row.className = 'merge-stop-toggle';

      /* Stop info */
      const infoDiv = document.createElement('div');
      infoDiv.className = 'stop-info';
      const nameEl = document.createElement('div');
      nameEl.className = 'stop-name';
      const anyStop = info.ours || info.theirs || info.base;
      nameEl.textContent = shortName(anyStop?.name || 'Stop');
      const dayEl = document.createElement('div');
      dayEl.className = 'stop-day';
      dayEl.textContent = dayGroup.date;
      infoDiv.appendChild(nameEl);
      infoDiv.appendChild(dayEl);
      row.appendChild(infoDiv);

      /* Options */
      const opts = document.createElement('div');
      opts.className = 'stop-options';

      const radioName = 'stop-' + key;
      const defaultChoice = _toggleDefaults[key] || 'base';

      [
        { value: 'base', label: 'Base', stop: info.base },
        { value: 'ours', label: 'Source', stop: info.ours },
        { value: 'theirs', label: 'Target', stop: info.theirs },
      ].forEach(opt => {
        const lbl = document.createElement('label');
        lbl.className = 'stop-option' + (opt.stop ? '' : ' opt-disabled');

        const radio = document.createElement('input');
        radio.type = 'radio';
        radio.name = radioName;
        radio.value = opt.value;
        if (opt.value === defaultChoice) radio.checked = true;
        if (!opt.stop) radio.disabled = true;
        radio.addEventListener('change', onToggleChange);
        lbl.appendChild(radio);

        const text = document.createElement('span');
        text.textContent = opt.label;
        lbl.appendChild(text);

        if (opt.stop && (opt.stop.arrive || opt.stop.depart)) {
          const time = document.createElement('span');
          time.className = 'opt-time';
          time.textContent = ' ' + (opt.stop.arrive || '?') + '\u2192' + (opt.stop.depart || '?');
          lbl.appendChild(time);
        } else if (!opt.stop) {
          const gone = document.createElement('span');
          gone.className = 'opt-time';
          gone.textContent = ' (none)';
          lbl.appendChild(gone);
        }

        opts.appendChild(lbl);
      });

      row.appendChild(opts);
      list.appendChild(row);
    });
  });

  container.appendChild(list);
}

function buildMergedFromToggles() {
  /* Start with conflict-resolved plan */
  let merged = applyResolutions();
  if (!merged) merged = clonePlan(mergedPlanBase);
  if (!merged) return null;

  /* Apply per-stop toggle overrides */
  _differingStops.forEach(info => {
    const key = info.dayId + '::' + info.stopId;
    const radioName = 'stop-' + key;
    const checked = document.querySelector('input[name="' + CSS.escape(radioName) + '"]:checked');
    if (!checked) return;

    const choice = checked.value;
    const pickPlan = choice === 'ours' ? ourPlan : choice === 'theirs' ? theirPlan : basePlan;
    const pd = pickPlan?.days?.find(d => d.id === info.dayId);
    const ps = pd ? (pd.stops || []).find(s => s && s.id === info.stopId) : null;

    const md = merged.days?.find(d => d.id === info.dayId);
    if (!md) {
      /* Day doesn't exist in merged plan; if we're adding a stop, create the day */
      if (ps) {
        if (!merged.days) merged.days = [];
        merged.days.push({ id: info.dayId, date: info.dayDate, stops: [JSON.parse(JSON.stringify(ps))] });
      }
      return;
    }

    if (!Array.isArray(md.stops)) md.stops = [];
    const idx = md.stops.findIndex(s => s && s.id === info.stopId);

    if (ps) {
      if (idx >= 0) {
        md.stops[idx] = JSON.parse(JSON.stringify(ps));
      } else {
        md.stops.push(JSON.parse(JSON.stringify(ps)));
      }
    } else {
      if (idx >= 0) md.stops.splice(idx, 1);
    }
  });

  return merged;
}

function onToggleChange() {
  const merged = buildMergedFromToggles();
  renderTimeline(document.getElementById('timelineMerged'), merged, conflictSet, null);
}

/* Collect per-stop toggle decisions for form submission */
function collectToggleDecisions() {
  const decisions = [];
  _differingStops.forEach(info => {
    const key = info.dayId + '::' + info.stopId;
    const radioName = 'stop-' + key;
    const checked = document.querySelector('input[name="' + CSS.escape(radioName) + '"]:checked');
    if (!checked) return;
    decisions.push({
      type: 'plan-stop-time',
      dayId: info.dayId,
      stopId: info.stopId,
      choice: checked.value,
    });
  });
  return decisions;
}

renderTimeline(document.getElementById('timelineBase'), basePlan, conflictSet, null);
renderTimeline(document.getElementById('timelineOurs'), ourPlan, conflictSet, ourDiffMap);
renderTimeline(document.getElementById('timelineTheirs'), theirPlan, conflictSet, theirDiffMap);
renderMergeToggles();
onToggleChange(); /* initial merged timeline render */

document.querySelectorAll('input[type="radio"][name^="c"]').forEach((el) => {
  el.addEventListener('change', () => {
    onToggleChange();
  });
});

/* ----- Diff Map ----- */
(function initDiffMap() {
  if (typeof L === 'undefined') return;
  var mapEl = document.getElementById('diffMap');
  if (!mapEl) return;

  var diffMap = L.map(mapEl);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 19,
    attribution: '&copy; OpenStreetMap contributors',
  }).addTo(diffMap);

  /* Build stop indices for each plan */
  var baseIdx = {}, ourIdx = {}, theirIdx = {};

  function indexPlan(plan, idx) {
    if (!plan || !Array.isArray(plan.days)) return;
    plan.days.forEach(function(d) {
      if (!d || !Array.isArray(d.stops)) return;
      d.stops.forEach(function(s) {
        if (s) idx[d.id + '::' + s.id] = s;
      });
    });
  }
  indexPlan(basePlan, baseIdx);
  indexPlan(ourPlan, ourIdx);
  indexPlan(theirPlan, theirIdx);

  /* Collect unique stops with diff status */
  var allKeys = {};
  [baseIdx, ourIdx, theirIdx].forEach(function(m) {
    Object.keys(m).forEach(function(k) { allKeys[k] = true; });
  });

  var colorMap = {
    added:     { color: '#065f46', fillColor: '#16a34a', fillOpacity: 0.8 },
    removed:   { color: '#991b1b', fillColor: '#ef4444', fillOpacity: 0.8 },
    modified:  { color: '#9a3412', fillColor: '#f97316', fillOpacity: 0.8 },
    unchanged: { color: '#6b7280', fillColor: '#9ca3af', fillOpacity: 0.5 },
  };

  var bounds = [];
  Object.keys(allKeys).forEach(function(key) {
    var bs = baseIdx[key], os = ourIdx[key], ts = theirIdx[key];
    var stop = os || ts || bs;
    if (!stop) return;
    var lat = Number(stop.lat), lng = Number(stop.lng);
    if (!Number.isFinite(lat) || !Number.isFinite(lng)) return;

    var inBase = !!bs, inOurs = !!os, inTheirs = !!ts;
    var status = 'unchanged';
    if (!inBase && (inOurs || inTheirs)) {
      status = 'added';
    } else if (inBase && !inOurs && !inTheirs) {
      status = 'removed';
    } else if (inBase) {
      var timeChanged =
        (inOurs && (os.arrive !== bs.arrive || os.depart !== bs.depart)) ||
        (inTheirs && (ts.arrive !== bs.arrive || ts.depart !== bs.depart));
      if (timeChanged) status = 'modified';
    }

    var style = colorMap[status] || colorMap.unchanged;
    var marker = L.circleMarker([lat, lng], {
      radius: 8, weight: 2,
      color: style.color, fillColor: style.fillColor, fillOpacity: style.fillOpacity,
    }).addTo(diffMap);

    var statusLabel = status.charAt(0).toUpperCase() + status.slice(1);
    marker.bindTooltip(
      '<strong>' + (stop.name || 'Stop') + '</strong><br>' +
      statusLabel +
      (stop.arrive ? '<br>' + stop.arrive + ' &rarr; ' + stop.depart : ''),
      { direction: 'top' }
    );

    bounds.push([lat, lng]);
  });

  if (bounds.length) {
    diffMap.fitBounds(bounds, { padding: [30, 30], maxZoom: 14 });
  } else {
    diffMap.setView([51.5074, -0.1278], 11);
    mapEl.innerHTML = '<div class="plan-preview-empty" style="padding:20px;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);z-index:1000;background:rgba(255,255,255,0.9);border-radius:8px">No stops with coordinates</div>';
  }

  setTimeout(function() { diffMap.invalidateSize(); }, 200);
})();

/* ---- Feature 2: Unified diff view toggle ---- */
(function initDiffViewToggle() {
  const toggleContainer = document.getElementById('diffViewToggle');
  if (!toggleContainer) return;
  const gridEl = document.querySelector('.plan-diff-grid');
  const unifiedEl = document.getElementById('planDiffUnified');
  if (!gridEl || !unifiedEl) return;

  const buttons = toggleContainer.querySelectorAll('button');

  function setView(view) {
    buttons.forEach(btn => {
      btn.classList.toggle('active', btn.dataset.view === view);
    });
    if (view === 'unified') {
      gridEl.classList.add('hidden');
      unifiedEl.classList.add('visible');
    } else {
      gridEl.classList.remove('hidden');
      unifiedEl.classList.remove('visible');
    }
  }

  buttons.forEach(btn => {
    btn.addEventListener('click', () => setView(btn.dataset.view));
  });

  /* Default: unified on mobile, side-by-side on desktop */
  if (window.innerWidth <= 900) {
    setView('unified');
  }
})();

/* ---- Feature 3: Conflict count badge ---- */
(function initConflictBadge() {
  const badge = document.getElementById('conflictBadge');
  const countEl = document.getElementById('conflictBadgeCount');
  const totalEl = document.getElementById('conflictBadgeTotal');
  if (!badge || !countEl || !totalEl) return;

  const metas = document.querySelectorAll('input[id^="meta"]');
  const total = metas.length;
  totalEl.textContent = total;

  function updateBadge() {
    /* Count resolved: any conflict with a checked radio is considered resolved */
    let resolved = 0;
    metas.forEach((m, i) => {
      const checked = document.querySelector('input[name="c' + i + '"]:checked');
      if (checked) resolved++;
    });
    countEl.textContent = resolved;
    badge.classList.toggle('all-resolved', resolved === total);
  }

  updateBadge();

  /* Listen for changes on conflict radios */
  document.querySelectorAll('input[type="radio"][name^="c"]').forEach(el => {
    el.addEventListener('change', updateBadge);
  });
})();

/* ---- Feature 4: Merged plan preview ---- */
function renderMergedPlanPreview() {
  const container = document.getElementById('mergedPlanPreview');
  if (!container) return;

  const merged = buildMergedFromToggles();
  if (!merged || !Array.isArray(merged.days) || !merged.days.length) {
    container.innerHTML = '<div class="plan-preview-empty">No plan data available</div>';
    return;
  }

  let html = '';
  merged.days.forEach(d => {
    if (!d) return;
    html += '<div class="plan-preview-day">';
    html += '<div class="plan-preview-day-title">' + escapeHtml(d.date || d.id || 'Day') + '</div>';
    const stops = Array.isArray(d.stops) ? d.stops : [];
    if (!stops.length) {
      html += '<div class="plan-preview-empty">No stops</div>';
    } else {
      stops.forEach(s => {
        if (!s) return;
        html += '<div class="plan-preview-stop">';
        html += '<strong>' + escapeHtml(s.name || 'Untitled stop') + '</strong>';
        if (s.arrive || s.depart) {
          html += ' <span class="time">' + escapeHtml(s.arrive || '??:??') + ' &rarr; ' + escapeHtml(s.depart || '??:??') + '</span>';
        }
        html += '</div>';
      });
    }
    html += '</div>';
  });

  container.innerHTML = html;
}

function escapeHtml(str) {
  const div = document.createElement('div');
  div.appendChild(document.createTextNode(String(str)));
  return div.innerHTML;
}

/* Initial render + hook into change events */
renderMergedPlanPreview();

/* Re-render preview whenever conflict radios or stop toggles change */
const _origOnToggleChange = onToggleChange;
onToggleChange = function() {
  _origOnToggleChange();
  renderMergedPlanPreview();
};

/* Also listen to conflict resolution radios for preview updates */
document.querySelectorAll('input[type="radio"][name^="c"]').forEach(el => {
  el.addEventListener('change', renderMergedPlanPreview);
});
</script>
