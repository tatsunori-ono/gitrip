<section class="container">
  <div class="card" style="max-width:420px; margin:24px auto">
    <h1>Create an account</h1>
    <p class="time">
      You can plan and optimise trips without an account.
      Sign up only if you want to share or collaborate on trips.
    </p>

    <% if (error) { %>
      <p style="color:#b91c1c; font-size:13px; margin-top:8px"><%= error %></p>
    <% } %>

    <form method="post" action="/ui/signup" style="margin-top:12px">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="next" value="<%= next %>" />

      <label>
        Email
        <input type="email" name="email" required value="<%= values.email || '' %>">
      </label>

      <label>
        Name (optional)
        <input type="text" name="name" value="<%= values.name || '' %>">
      </label>

      <label>
        Password
        <span class="pw-wrap">
          <input type="password" name="password" id="signupPassword" required minlength="10">
          <button type="button" class="pw-toggle" data-pw-target="signupPassword"
                  aria-label="Show password" aria-pressed="false">
            <svg class="pw-icon pw-icon-show" viewBox="0 0 24 24" width="18" height="18"
                 fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
            <svg class="pw-icon pw-icon-hide" viewBox="0 0 24 24" width="18" height="18"
                 fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                 style="display:none">
              <path d="M17.94 17.94A10.94 10.94 0 0 1 12 20c-7 0-11-8-11-8a19.77 19.77 0 0 1 5.06-5.94"/>
              <path d="M9.9 4.24A10.94 10.94 0 0 1 12 4c7 0 11 8 11 8a19.86 19.86 0 0 1-3.17 4.19"/>
              <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/>
              <line x1="1" y1="1" x2="23" y2="23"/>
            </svg>
          </button>
        </span>
      </label>
      <ul class="pw-rules" id="pwRules">
        <li id="pwLen"><span class="pw-circle"></span> At least 10 characters</li>
        <li id="pwUpper"><span class="pw-circle"></span> One uppercase letter</li>
        <li id="pwLower"><span class="pw-circle"></span> One lowercase letter</li>
        <li id="pwNum"><span class="pw-circle"></span> One number</li>
      </ul>

      <label>
        Confirm password
        <span class="pw-wrap">
          <input type="password" name="confirm" id="signupConfirm" required minlength="10">
          <button type="button" class="pw-toggle" data-pw-target="signupConfirm"
                  aria-label="Show password" aria-pressed="false">
            <svg class="pw-icon pw-icon-show" viewBox="0 0 24 24" width="18" height="18"
                 fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
            <svg class="pw-icon pw-icon-hide" viewBox="0 0 24 24" width="18" height="18"
                 fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                 style="display:none">
              <path d="M17.94 17.94A10.94 10.94 0 0 1 12 20c-7 0-11-8-11-8a19.77 19.77 0 0 1 5.06-5.94"/>
              <path d="M9.9 4.24A10.94 10.94 0 0 1 12 4c7 0 11 8 11 8a19.86 19.86 0 0 1-3.17 4.19"/>
              <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/>
              <line x1="1" y1="1" x2="23" y2="23"/>
            </svg>
          </button>
        </span>
      </label>
      <ul class="pw-rules" id="pwMatchRules" style="display:none">
        <li id="pwMatch"><span class="pw-circle"></span> Passwords match</li>
      </ul>

      <p class="time" style="margin-top:8px">
        By signing up, you agree to our
        <a href="/ui/terms">Terms of Use</a> and
        <a href="/ui/privacy">Privacy Policy</a>.
      </p>

      <div class="section-actions">
        <button class="btn btn-primary" type="submit">Sign up</button>
        <a class="time" href="/ui/login?next=<%= encodeURIComponent(next) %>">
          Already have an account? Sign in
        </a>
      </div>
    </form>
  </div>
</section>

<style>
  .pw-rules {
    list-style: none;
    padding: 0;
    margin: 4px 0 0;
    font-size: 13px;
    color: var(--muted, #667085);
  }
  .pw-rules li {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 2px 0;
  }
  .pw-circle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 2px solid #d0d5dd;
    flex-shrink: 0;
    transition: border-color 0.2s, background 0.2s;
  }
  .pw-rules li.pass .pw-circle {
    border-color: #16a34a;
    background: #16a34a;
  }
  .pw-rules li.pass .pw-circle::after {
    content: '';
    display: block;
    width: 5px;
    height: 9px;
    border: solid #fff;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
    margin-bottom: 2px;
  }
  .pw-rules li.pass {
    color: #16a34a;
  }
  .pw-wrap {
    position: relative;
    display: block;
  }
  .pw-wrap input {
    width: 100%;
    padding-right: 40px;
    box-sizing: border-box;
  }
  .pw-toggle {
    position: absolute;
    top: 50%;
    right: 8px;
    transform: translateY(-50%);
    background: transparent;
    border: 0;
    padding: 4px;
    cursor: pointer;
    color: var(--muted, #667085);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
  }
  .pw-toggle:hover { color: var(--text, #111827); }
  .pw-toggle:focus-visible {
    outline: 2px solid #2563eb;
    outline-offset: 1px;
  }
</style>

<script>
  (function () {
    var pw = document.getElementById('signupPassword');
    var confirm = document.getElementById('signupConfirm');
    var matchWrap = document.getElementById('pwMatchRules');
    if (!pw || !confirm) return;

    var rules = [
      { id: 'pwLen', test: function (v) { return v.length >= 10; } },
      { id: 'pwUpper', test: function (v) { return /[A-Z]/.test(v); } },
      { id: 'pwLower', test: function (v) { return /[a-z]/.test(v); } },
      { id: 'pwNum', test: function (v) { return /[0-9]/.test(v); } },
    ];

    function checkPassword() {
      var val = pw.value;
      rules.forEach(function (r) {
        var el = document.getElementById(r.id);
        if (!el) return;
        if (r.test(val)) {
          el.classList.add('pass');
        } else {
          el.classList.remove('pass');
        }
      });
      checkMatch();
    }

    function checkMatch() {
      var cVal = confirm.value;
      if (cVal.length > 0) {
        matchWrap.style.display = '';
        var el = document.getElementById('pwMatch');
        if (el) {
          if (pw.value === cVal && cVal.length > 0) {
            el.classList.add('pass');
          } else {
            el.classList.remove('pass');
          }
        }
      } else {
        matchWrap.style.display = 'none';
      }
    }

    pw.addEventListener('input', checkPassword);
    confirm.addEventListener('input', checkMatch);

    document.querySelectorAll('.pw-toggle').forEach(function (btn) {
      var target = document.getElementById(btn.getAttribute('data-pw-target'));
      if (!target) return;
      var showIcon = btn.querySelector('.pw-icon-show');
      var hideIcon = btn.querySelector('.pw-icon-hide');
      btn.addEventListener('click', function () {
        var visible = target.type === 'text';
        target.type = visible ? 'password' : 'text';
        btn.setAttribute('aria-pressed', String(!visible));
        btn.setAttribute('aria-label', visible ? 'Show password' : 'Hide password');
        showIcon.style.display = visible ? '' : 'none';
        hideIcon.style.display = visible ? 'none' : '';
      });
    });
  })();
</script>
